{
  "_sample_comment": "这是一个 sample，文件实质完成后删掉这行注释",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Writing Work Item State",
  "type": "object",
  "required": [
    "schema_version",
    "work_item_id",
    "derived_author_id",
    "derived_author_model_id",
    "derived_author_model_version",
    "runbook_id",
    "runbook_version",
    "runtime_adapter_id",
    "runtime_adapter_version",
    "lifecycle_status",
    "stage_executions",
    "quality_gates",
    "publication",
    "archive_reason"
  ],
  "properties": {
    "_sample_comment": {"type": "string"},
    "schema_version": {"type": "string"},
    "work_item_id": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{3}-[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "derived_author_id": {"type": "string"},
    "derived_author_model_id": {"type": "string"},
    "derived_author_model_version": {"type": "string"},
    "runbook_id": {"type": "string"},
    "runbook_version": {"type": "string"},
    "runtime_adapter_id": {"type": "string"},
    "runtime_adapter_version": {"type": "string"},
    "lifecycle_status": {"enum": ["intake", "in-progress", "under-review", "approved", "published", "rejected", "cancelled", "abandoned", "superseded", "archived"]},
    "stage_executions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {"enum": ["not-started", "in-progress", "completed", "failed", "skipped"]},
          "started_at": {"type": ["string", "null"], "format": "date-time"},
          "completed_at": {"type": ["string", "null"], "format": "date-time"},
          "run_id": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    },
    "quality_gates": {
      "type": "object",
      "required": ["factual_accuracy", "persona_and_style", "editorial_approval"],
      "properties": {
        "factual_accuracy": {"enum": ["not-evaluated", "pending", "passed", "failed"]},
        "persona_and_style": {"enum": ["not-evaluated", "pending", "passed", "failed"]},
        "editorial_approval": {"enum": ["not-evaluated", "pending", "approved", "changes-requested", "rejected"]}
      },
      "additionalProperties": false
    },
    "publication": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["publication_id", "publication_status", "canonical_file", "published_at"],
          "properties": {
            "publication_id": {"type": "string", "pattern": "^publication-[0-9]{4}-[0-9]{3}-[a-z0-9]+(?:-[a-z0-9]+)*$"},
            "publication_status": {"enum": ["approved", "published", "withdrawn"]},
            "canonical_file": {"type": "string", "minLength": 1},
            "published_at": {"type": ["string", "null"], "format": "date-time"}
          },
          "additionalProperties": false
        }
      ]
    },
    "archive_reason": {"type": ["string", "null"], "minLength": 1}
  },
  "additionalProperties": false
}

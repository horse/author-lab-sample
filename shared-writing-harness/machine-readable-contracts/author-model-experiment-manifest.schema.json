{
  "_sample_comment": "这是一个 sample，文件实质完成后删掉这行注释",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Author Model Experiment Manifest",
  "type": "object",
  "required": [
    "experiment_id",
    "experiment_status",
    "hypothesis_file",
    "controlled_input_directory",
    "controlled_execution",
    "conditions",
    "held_out_evaluation_pack_uri",
    "runtime_run_records_directory",
    "raw_evaluation_results_file",
    "aggregate_analysis_file",
    "failure_cases_directory",
    "conclusion_file"
  ],
  "properties": {
    "_sample_comment": {"type": "string"},
    "experiment_id": {"type": "string", "pattern": "^experiment-[0-9]{4}-[0-9]{3}-[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "experiment_status": {"enum": ["designed", "ready-to-run", "running", "evaluating", "completed", "cancelled"]},
    "hypothesis_file": {"type": "string"},
    "controlled_input_directory": {"type": "string"},
    "controlled_execution": {
      "type": "object",
      "required": [
        "runtime_adapter_id",
        "runtime_adapter_version",
        "runbook_id",
        "runbook_version",
        "model_parameters",
        "context_budget_tokens",
        "tool_permissions",
        "repetition_count",
        "randomness_control"
      ],
      "properties": {
        "runtime_adapter_id": {"type": "string"},
        "runtime_adapter_version": {"type": "string"},
        "runbook_id": {"type": "string"},
        "runbook_version": {"type": "string"},
        "model_parameters": {"type": "object"},
        "context_budget_tokens": {"type": ["integer", "null"], "minimum": 1},
        "tool_permissions": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "repetition_count": {"type": "integer", "minimum": 1},
        "randomness_control": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "conditions": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["condition_id", "condition_role", "author_condition"],
        "properties": {
          "condition_id": {"type": "string"},
          "condition_role": {"enum": ["generic-runtime-baseline", "source-model-direct-baseline", "derived-author-b", "derived-author-c", "additional-controlled-condition"]},
          "author_condition": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    },
    "held_out_evaluation_pack_uri": {"type": "string", "pattern": "^evaluator-storage://"},
    "runtime_run_records_directory": {"type": "string"},
    "raw_evaluation_results_file": {"type": "string"},
    "aggregate_analysis_file": {"type": "string"},
    "failure_cases_directory": {"type": "string"},
    "conclusion_file": {"type": "string"}
  },
  "allOf": [
    {
      "if": {
        "properties": {"experiment_status": {"enum": ["ready-to-run", "running", "evaluating", "completed"]}},
        "required": ["experiment_status"]
      },
      "then": {
        "properties": {
          "controlled_execution": {
            "properties": {
              "context_budget_tokens": {"type": "integer", "minimum": 1},
              "randomness_control": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}

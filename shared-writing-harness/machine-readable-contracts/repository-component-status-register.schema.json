{
  "_sample_comment": "这是一个 sample，文件实质完成后删掉这行注释",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Repository Component Status Register",
  "type": "object",
  "required": ["schema_version", "components"],
  "properties": {
    "_sample_comment": {"type": "string"},
    "schema_version": {"type": "string"},
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["component_id", "path", "component_class", "implementation_status", "validation_status", "production_ready"],
        "properties": {
          "component_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
          "path": {"type": "string", "minLength": 1},
          "component_class": {"enum": ["core", "optional", "example"]},
          "implementation_status": {"enum": ["placeholder", "scaffolded", "partially-implemented", "implemented", "experimentally-validated", "example", "deprecated"]},
          "validation_status": {"type": "string", "minLength": 1},
          "production_ready": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

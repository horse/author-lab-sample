{
  "_sample_comment": "这是一个 sample，文件实质完成后删掉这行注释",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Factual Review Result",
  "type": "object",
  "required": ["work_item_id", "review_status", "claims"],
  "properties": {
    "_sample_comment": {"type": "string"},
    "work_item_id": {"type": "string"},
    "review_status": {"enum": ["pending", "passed", "failed"]},
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "claim_text", "claim_type", "support_status"],
        "properties": {
          "claim_id": {"type": "string"},
          "claim_text": {"type": "string"},
          "claim_type": {"enum": ["verified-fact", "reported-claim", "analysis-inference", "literary-construction", "unsupported-speculation"]},
          "support_status": {"enum": ["supported", "partially-supported", "unsupported", "not-applicable"]},
          "source_ids": {"type": "array", "items": {"type": "string"}},
          "as_of_date": {"type": ["string", "null"], "format": "date"}
        }
      }
    }
  },
  "additionalProperties": true
}

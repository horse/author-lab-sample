{
  "_sample_comment": "这是一个 sample，文件实质完成后删掉这行注释",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Policy Rule Record",
  "type": "object",
  "required": ["policy_rule_id", "policy_file", "rule_summary", "enforcement_scope"],
  "properties": {
    "_sample_comment": {"type": "string"},
    "policy_rule_id": {"type": "string", "pattern": "^POLICY-[A-Z]+-[0-9]{3}$"},
    "policy_file": {"type": "string"},
    "rule_summary": {"type": "string", "minLength": 1},
    "enforcement_scope": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  },
  "additionalProperties": false
}

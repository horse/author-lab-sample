{
  "_sample_comment": "这是一个 sample，文件实质完成后删掉这行注释",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "author-lab-project-manifest.schema.json",
  "title": "Author Lab Project Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "project_id",
    "project_type",
    "default_language",
    "repository_mode",
    "readiness_status",
    "source_author_directories",
    "source_author_model_directories",
    "derived_author_persona_directories",
    "shared_writing_harness_directory",
    "runtime_adapters_directory",
    "writing_work_items_directory",
    "author_model_evaluations_directory",
    "author_model_experiments_directory",
    "approved_publications_directory",
    "component_status_register",
    "placeholder_register",
    "source_material_storage_register",
    "document_schema_registry",
    "persona_scaffold_template_manifest",
    "policy_rule_register",
    "rights_policy",
    "ethics_policy"
  ],
  "properties": {
    "_sample_comment": {"type": "string"},
    "schema_version": {"type": "string"},
    "project_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "project_type": {"const": "source-author-and-derived-author-laboratory"},
    "default_language": {"type": "string"},
    "repository_mode": {"enum": ["reference-sample", "active-author-lab"]},
    "readiness_status": {"enum": ["scaffold", "pre-real-run-complete", "experiment-running", "operational"]},
    "source_author_directories": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "source_author_model_directories": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "derived_author_persona_directories": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "shared_writing_harness_directory": {"type": "string"},
    "runtime_adapters_directory": {"type": "string"},
    "writing_work_items_directory": {"type": "string"},
    "author_model_evaluations_directory": {"type": "string"},
    "author_model_experiments_directory": {"type": "string"},
    "approved_publications_directory": {"type": "string"},
    "component_status_register": {"type": "string"},
    "placeholder_register": {"type": "string"},
    "source_material_storage_register": {"type": "string"},
    "document_schema_registry": {"type": "string"},
    "persona_scaffold_template_manifest": {"type": "string"},
    "policy_rule_register": {"type": "string"},
    "rights_policy": {"type": "string"},
    "ethics_policy": {"type": "string"}
  },
  "additionalProperties": false
}

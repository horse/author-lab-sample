{
  "_sample_comment": "这是一个 sample，文件实质完成后删掉这行注释",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source Author Model Provenance Record",
  "type": "object",
  "required": [
    "source_author_id",
    "source_author_model_id",
    "model_rule_id",
    "research_claim_ids",
    "model_file",
    "status"
  ],
  "properties": {
    "_sample_comment": {"type": "string"},
    "source_author_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "source_author_model_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "model_rule_id": {"type": "string", "pattern": "^SOURCE-MODEL-RULE-[0-9]{4,}$"},
    "research_claim_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^RESEARCH-CLAIM-[0-9]{4,}$"}, "uniqueItems": true},
    "model_file": {"type": "string", "minLength": 1},
    "status": {"enum": ["proposed", "approved", "rejected", "superseded", "sample-unreviewed"]}
  },
  "additionalProperties": false
}

{
  "_sample_comment": "这是一个 sample，文件实质完成后删掉这行注释",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Experiment Runtime Run Record",
  "type": "object",
  "required": [
    "experiment_run_id",
    "experiment_id",
    "condition_id",
    "repetition_number",
    "run_status",
    "repository_commit_sha",
    "runtime_adapter_id",
    "runtime_adapter_version",
    "runbook_id",
    "runbook_version",
    "model_identifier",
    "model_parameters",
    "context_budget_tokens",
    "tool_permissions",
    "loaded_file_records",
    "started_at",
    "completed_at",
    "exit_status",
    "output_artifacts"
  ],
  "properties": {
    "_sample_comment": {"type": "string"},
    "experiment_run_id": {"type": "string", "minLength": 1},
    "experiment_id": {"type": "string", "pattern": "^experiment-"},
    "condition_id": {"type": "string", "minLength": 1},
    "repetition_number": {"type": "integer", "minimum": 1},
    "run_status": {"enum": ["running", "completed", "failed", "cancelled", "excluded"]},
    "repository_commit_sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "runtime_adapter_id": {"type": "string"},
    "runtime_adapter_version": {"type": "string"},
    "runbook_id": {"type": "string"},
    "runbook_version": {"type": "string"},
    "model_identifier": {"type": "string", "minLength": 1},
    "model_parameters": {"type": "object"},
    "context_budget_tokens": {"type": "integer", "minimum": 1},
    "tool_permissions": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "loaded_file_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        },
        "additionalProperties": false
      }
    },
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": ["string", "null"], "format": "date-time"},
    "exit_status": {"type": ["integer", "null"]},
    "output_artifacts": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "exclusion_reason": {"type": "string"}
  },
  "additionalProperties": false
}

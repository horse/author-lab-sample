{
  "_sample_comment": "这是一个 sample，文件实质完成后删掉这行注释",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source Segment Location Record",
  "type": "object",
  "required": [
    "source_id",
    "edition_id",
    "segmentation_version",
    "segment_id",
    "segment_ordinal",
    "content_sha256",
    "character_count"
  ],
  "properties": {
    "_sample_comment": {"type": "string"},
    "source_id": {"type": "string", "pattern": "^SOURCE-"},
    "edition_id": {"type": "string", "pattern": "^edition-[0-9]{2,}$"},
    "segmentation_version": {"type": "string", "pattern": "^segmentation-[0-9]{2,}$"},
    "segment_id": {"type": "string", "minLength": 1},
    "segment_ordinal": {"type": "integer", "minimum": 1},
    "content_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "character_count": {"type": "integer", "minimum": 1}
  },
  "additionalProperties": false
}
